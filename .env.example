# ---------------------------------------------------------------------------
# Message Gateway – monorepo environment variables (example).
# Copy to `.env` (git-ignored) and adjust per environment.
# ---------------------------------------------------------------------------

# General
COMPOSE_PROJECT_NAME=msg-gateway
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Backend (FastAPI)
# ---------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
# 32-byte URL-safe secret; rotate in production.
SECRET_KEY=change-me-in-production
# Comma separated list; "*" allows all (development only).
CORS_ALLOW_ORIGINS=http://localhost:4200

# ---------------------------------------------------------------------------
# Auth & registration
# ---------------------------------------------------------------------------
# Cost factor for the bcrypt hashes of client passwords and API
# keys. 12 is the OWASP-recommended minimum for 2024+. Lower in
# dev to keep unit tests fast; never go below 4 in any non-test
# environment.
BCRYPT_ROUNDS=12
# HMAC secret used to sign the dashboard session JWT minted by
# `POST /v1/auth/login`. Falls back to `SECRET_KEY` if unset but
# keeping the two independent lets you rotate one without the
# other.
JWT_SECRET=change-me-in-production-jwt
# HS256 keeps the token verifiable by the API process without
# requiring a public-key infra in the MVP.
JWT_ALGORITHM=HS256
# Dashboard session lifetime in minutes. 60 (one hour) is the
# default; rotate in production to suit the dashboard UX.
JWT_TTL_MINUTES=60
# Public prefix attached to every API key we mint (`mgw_live_…`).
# Keeping it short and stable lets integrators grep for it in
# their own config / secret stores.
API_KEY_PREFIX=mgw_live_

# ---------------------------------------------------------------------------
# Provider integrations (issue #4)
# ---------------------------------------------------------------------------
# Meta Cloud API – WhatsApp. The platform owns the WABA and
# every client sends through the same `phone_number_id`. The
# access token is the long-lived bearer the Cloud API expects
# on every call. `META_WHATSAPP_API_VERSION` defaults to
# `v22.0` (see PRD "Stack técnico") and should be bumped
# alongside Meta's deprecation calendar.
META_WHATSAPP_ACCESS_TOKEN=change-me-meta-token
META_WHATSAPP_PHONE_NUMBER_ID=change-me-phone-id
META_WHATSAPP_API_BASE=https://graph.facebook.com
META_WHATSAPP_API_VERSION=v22.0
# Local Chilean SMS aggregator. `SMS_AGGREGATOR_SENDER_ID` is
# the alphanumeric "from" string the operator prints on the
# recipient's handset (max 11 chars for GSM).
SMS_AGGREGATOR_API_URL=https://sms.aggregator.cl
SMS_AGGREGATOR_API_KEY=change-me-sms-aggregator-key
SMS_AGGREGATOR_SENDER_ID=MSGGTWY
# Default timeout (in seconds) applied to every provider HTTP
# call. Kept low so a misconfigured upstream fails the request
# fast instead of stalling on a TCP handshake.
PROVIDER_TIMEOUT_SECONDS=10
# Provider failover chains (issue #11). JSON object that maps
# each channel to an ordered list of providers – the first
# element is the primary, the rest are tried in order when the
# primary returns a retryable error (5xx or 429). Validation
# errors (4xx) are *not* retried: a bad number stays a bad
# number against every upstream. The MVP ships only
# `meta_whatsapp` and `sms_aggregator`; the chain becomes
# meaningful as soon as a second provider is registered (e.g.
# a Twilio WhatsApp adapter). An empty object disables
# failover – the registry returns the single primary adapter.
# Example:
# PROVIDER_FAILOVER_CHAINS={"whatsapp":["meta_whatsapp","twilio_whatsapp"],"sms":["sms_aggregator","twilio_sms"]}
PROVIDER_FAILOVER_CHAINS={}

# ---------------------------------------------------------------------------
# Webhooks – delivery receipts (issue #5)
# ---------------------------------------------------------------------------
# Timeout (in seconds) for outbound POSTs the platform sends to
# customer-configured webhook URLs. Kept tighter than the provider
# timeout (5s vs 10s) so a misconfigured customer endpoint cannot
# stall the delivery worker for more than a short bounded interval.
WEBHOOK_DELIVERY_TIMEOUT_SECONDS=5
# Maximum number of delivery attempts the platform will make for a
# single receipt before giving up. The exponential back-off is
# calculated by the service layer (no setting for it – the values
# are documented in the service module).
WEBHOOK_MAX_DELIVERY_ATTEMPTS=5

# ---------------------------------------------------------------------------
# Batch messaging (issue #9)
# ---------------------------------------------------------------------------
# Maximum number of ``POST /v1/messages/batch`` calls a single
# customer is allowed to issue per second. Enforced by a Redis-backed
# sliding window in `app/services/rate_limit.py` so a runaway client
# cannot flood the worker queue. 100/s matches the "100 msg/s por
# API Key" promise in the PRD.
BATCH_RATE_LIMIT_PER_SECOND=100
# Timeout (in seconds) for the batch-completion webhook POST. Mirrors
# ``WEBHOOK_DELIVERY_TIMEOUT_SECONDS`` so a misconfigured
# ``webhook_url`` cannot stall the response for more than the same
# bounded interval the per-message delivery receipts use.
BATCH_WEBHOOK_TIMEOUT_SECONDS=5
# Maximum number of delivery attempts the platform will make for a
# single batch-completion POST before giving up. Mirrors
# ``WEBHOOK_MAX_DELIVERY_ATTEMPTS`` so a flaky customer endpoint
# cannot consume the worker's quota indefinitely.
BATCH_WEBHOOK_MAX_DELIVERY_ATTEMPTS=5

# ---------------------------------------------------------------------------
# Billing & payments
# ---------------------------------------------------------------------------
# Currency the platform charges in. The MVP is CLP-only; the
# field is exposed for the eventual "USD for international
# tenants" rollout.
BILLING_CURRENCY=CLP
# Chilean IVA rate (0.19 = 19%). The SII has kept this rate
# stable since 2003, but the field is exposed so an
# export-only deployment can set it to 0.
BILLING_IVA_RATE=0.19
# Number of days an invoice stays open before it is marked
# ``overdue``. 30 matches the "monthly billing" promise in the
# PRD; prepaid enterprise contracts may set this to 0 to make
# invoices due immediately.
BILLING_DUE_DAYS=30
# Plan code assigned to a newly-registered client when the
# ``POST /v1/auth/register`` body omits the ``plan`` field.
# Must match a row in the ``planes`` table (seeded in
# migration 0003).
BILLING_DEFAULT_PLAN_CODE=starter

# Flow (Chilean payment gateway – Webpay / cards). The
# sandbox credentials are safe to commit; production
# deployments MUST set the production pair in the secret
# store.
FLOW_API_KEY=sandbox-api-key
FLOW_SECRET_KEY=sandbox-secret-key
# Sandbox base URL; production swaps to https://www.flow.cl/api.
FLOW_BASE_URL=https://sandbox.flow.cl/api
FLOW_ENVIRONMENT=sandbox
# Where Flow sends the customer after a successful payment
# (the dashboard polls the payment status from this URL).
FLOW_CONFIRMATION_URL=https://app.msg-gateway.cl/billing/return
# Where Flow sends the customer if they cancel the payment.
FLOW_RETURN_URL=https://app.msg-gateway.cl/billing/cancel
# The platform's webhook endpoint – Flow POSTs the
# asynchronous payment confirmation here.
FLOW_WEBHOOK_URL=https://api.msg-gateway.cl/v1/billing/webhook/flow

# DTE (Documento Tributario Electrónico) – the platform's
# legal identity as the invoice issuer. Production values come
# from the SII resolution the platform operates under.
DTE_EMISOR_RUT=76.123.456-7
DTE_EMISOR_RAZON_SOCIAL=Message Gateway SpA
DTE_EMISOR_GIRO=Servicios de Telecomunicaciones
DTE_EMISOR_DIRECCION=Av. Apoquindo 4711, Piso 12
DTE_EMISOR_COMUNA=Las Condes
DTE_EMISOR_CIUDAD=Santiago
DTE_RESOLUTION_NUMBER=0
DTE_RESOLUTION_DATE=2024-01-01
DTE_SII_OFFICE=Santiago Oriente

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=msg_gateway
POSTGRES_PASSWORD=msg_gateway
POSTGRES_DB=msg_gateway
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis (queue + cache + rate limiting)
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# Frontend (Angular)
# ---------------------------------------------------------------------------
FRONTEND_PORT=4200
# Public origin used by the Angular build. In Docker this points to the
# proxied API path; in local dev it points to the FastAPI host:port.
API_BASE_URL=/api
